{
  "name": "prometheus-gateway",
  "version": "0.1.0-genesis",
  "private": true,
  "type": "module",
  "description": "Sensor -> Holochain ingest adapter (MQTT/Mosquitto -> create_evidence). Runs on the gateway (e.g. Raspberry Pi 5), local-first.",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "node src/ingest.mjs",
    "dry-run": "PROMETHEUS_DRY_RUN=1 node src/ingest.mjs",
    "smoke": "node scripts/smoke.mjs",
    "e2e": "node scripts/e2e_verify.mjs",
    "wp4": "bash scripts/run_wp4.sh"
  },
  "dependencies": {
    "@holochain/client": "0.20.5",
    "mqtt": "5.15.1"
  },
  "license": "UNLICENSED"
}
