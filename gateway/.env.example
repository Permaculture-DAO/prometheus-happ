# Prometheus gateway — site config template. Copy to /etc/prometheus/gateway.env
# (NOT committed; no secrets in git). See ops-docs Raspberry Pi runbook + the pilot
# SENSOR_INTEGRATION_SPEC. Until PROMETHEUS_ALLOW_REAL=1, every reading is forced to TEST.

# --- MQTT broker (Mosquitto on the gateway) ---
MQTT_URL=mqtt://127.0.0.1:1883
MQTT_TOPIC=prometheus/+/+
MQTT_USERNAME=sensors
MQTT_PASSWORD=            # set a strong password (mosquitto_passwd)
MQTT_RECONNECT_MS=1000

# --- Conductor connection ---
# Launcher/hc-spin: leave PROMETHEUS_ADMIN_PORT unset (env injected).
# Standalone (separate process next to a headless conductor): set the admin port.
PROMETHEUS_ADMIN_PORT=
PROMETHEUS_APP_PORT=
PROMETHEUS_APP_ID=hearth_prometheus_web
PROMETHEUS_ROLE=hearth

# --- Default subject + indicators ---
PROMETHEUS_SUBJECT_ID=ohe-sintropico-1
# PROMETHEUS_INDICATORS=soil_moisture,precipitation,...   # extend the allowlist if needed

# --- Sensor authenticity (recommended on a LAN) ---
PROMETHEUS_REQUIRE_SIGNATURE=0     # 1 = require HMAC-signed readings
PROMETHEUS_HMAC_KEY=               # shared key when REQUIRE_SIGNATURE=1

# --- Reliability ---
PROMETHEUS_MAX_RETRIES=3

# ============================================================================
# GO-LIVE GATE — the single switch from rehearsal to real evidence.
# Keep 0 until: reviewer appointed + units/comparator/dates set + pre-registration
# re-frozen & signed + baseline recorded & attested. (See pilot activation checklist.)
PROMETHEUS_ALLOW_REAL=0
# ============================================================================
